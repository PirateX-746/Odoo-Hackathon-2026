// TransitOps — Smart Transport Operations Platform
// Prisma schema: Users/RBAC, Vehicles, Drivers, Trips, Maintenance, Fuel Logs, Expenses

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  ACTIVE
  CLOSED
}

enum ExpenseType {
  TOLL
  MAINTENANCE
  OTHER
}

// ─── Models ──────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  name             String
  role             Role
  isActive         Boolean  @default(true)
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  driver       Driver?
  createdTrips Trip[]   @relation("TripCreatedBy")

  @@index([role])
}

model Vehicle {
  id                 String        @id @default(uuid())
  registrationNumber String        @unique
  name               String
  type               String
  maxLoadCapacityKg  Decimal       @db.Decimal(10, 2)
  odometerKm         Decimal       @default(0) @db.Decimal(12, 2)
  acquisitionCost    Decimal       @db.Decimal(14, 2)
  status             VehicleStatus @default(AVAILABLE)
  region             String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@index([status])
  @@index([region])
  @@index([type])
}

model Driver {
  id                String       @id @default(uuid())
  name              String
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Int          @default(100)
  status            DriverStatus @default(AVAILABLE)
  userId            String?      @unique
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user  User?  @relation(fields: [userId], references: [id])
  trips Trip[]

  @@index([status])
}

model Trip {
  id                 String     @id @default(uuid())
  source             String
  destination        String
  vehicleId          String
  driverId           String
  cargoWeightKg      Decimal    @db.Decimal(10, 2)
  plannedDistanceKm  Decimal    @db.Decimal(10, 2)
  actualDistanceKm   Decimal?   @db.Decimal(10, 2)
  startOdometerKm    Decimal?   @db.Decimal(12, 2)
  endOdometerKm      Decimal?   @db.Decimal(12, 2)
  fuelConsumedLiters Decimal?   @db.Decimal(10, 2)
  revenue            Decimal?   @db.Decimal(14, 2)
  status             TripStatus @default(DRAFT)
  dispatchedAt       DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  createdById        String
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  driver    Driver    @relation(fields: [driverId], references: [id])
  createdBy User      @relation("TripCreatedBy", fields: [createdById], references: [id])
  fuelLogs  FuelLog[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

model MaintenanceLog {
  id          String             @id @default(uuid())
  vehicleId   String
  type        String
  description String?
  cost        Decimal            @db.Decimal(12, 2)
  status      MaintenanceStatus  @default(ACTIVE)
  openedAt    DateTime           @default(now())
  closedAt    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([status])
}

model FuelLog {
  id        String   @id @default(uuid())
  vehicleId String
  tripId    String?
  liters    Decimal  @db.Decimal(10, 2)
  cost      Decimal  @db.Decimal(12, 2)
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])

  @@index([vehicleId])
  @@index([tripId])
}

model Expense {
  id          String      @id @default(uuid())
  vehicleId   String
  type        ExpenseType
  amount      Decimal     @db.Decimal(12, 2)
  date        DateTime
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([type])
}
